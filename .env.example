# Required for higher PubMed rate limits: 10 req/sec instead of 3 req/sec.
NCBI_API_KEY=

# Required by OpenAlex for production retrieval.
OPENALEX_API_KEY=

# Optional cache backend.
ADDA_CACHE_BACKEND=disk
ADDA_CACHE_DIR=.cache/adda
REDIS_URL=redis://localhost:6379/0

# Neo4j knowledge graph.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=addadev123

# Logging.
LOG_LEVEL=INFO
